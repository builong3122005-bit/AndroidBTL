<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:orientation="vertical">

    <!-- Khu vực hiển thị tiêu đề ứng dụng -->
    <LinearLayout
        android:id="@+id/convertlayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center">

        <!-- Tiêu đề Chuyển đổi -->
        <TextView
            android:id="@+id/tvconvert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Chuyển đổi"
            android:textColor="#1E1E24"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Phần chọn và nhập số tiền của loại tiền tệ thứ nhất -->
    <LinearLayout
        android:id="@+id/money1"
        android:layout_width="match_parent"
        android:layout_height="85dp"
        android:layout_weight="0"
        android:orientation="horizontal">

        <!-- Ảnh cờ của quốc gia thứ nhất -->
        <ImageView
            android:id="@+id/imgvietnam"
            android:layout_width="50dp"
            android:layout_height="65dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            app:srcCompat="@drawable/icon_usa" />

        <!-- Ô hiển thị số tiền đã nhập -->
        <TextView
            android:id="@+id/tvmoney1"
            android:layout_width="wrap_content"
            android:layout_height="65dp"
            android:layout_weight="9"
            android:text=""
            android:paddingRight="20dp"
            android:textSize="30sp"
            android:gravity="end|center_vertical"
            android:layout_marginTop="10dp"
            android:textColor="#1E1E24" />
    </LinearLayout>

    <Button
        android:id="@+id/btnngancach"
        android:layout_width="400dp"
        android:layout_height="1dp"
        android:text=""
        android:layout_gravity="center"
        android:backgroundTint="#E2E8F0" />

    <!-- Phần chọn và hiển thị số tiền quy đổi của loại tiền tệ thứ hai -->
    <LinearLayout
        android:id="@+id/money2"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:layout_weight="0"
        android:orientation="horizontal">

        <!-- Ảnh cờ của quốc gia thứ hai -->
        <ImageView
            android:id="@+id/imgusa"
            android:layout_width="50dp"
            android:layout_height="65dp"
            android:layout_weight="1"
            app:srcCompat="@drawable/icon_vietnam"
            android:layout_marginTop="7dp" />

        <!-- Ô hiển thị số tiền quy đổi tương ứng -->
        <TextView
            android:id="@+id/tvmoney2"
            android:layout_width="wrap_content"
            android:layout_height="65dp"
            android:layout_weight="9"
            android:text=""
            android:paddingRight="20dp"
            android:textSize="30sp"
            android:gravity="end|center_vertical"
            android:textColor="#1E1E24"
            android:layout_marginTop="7dp" />
    </LinearLayout>

    <!-- Dòng hiển thị tỉ giá quy đổi và nút làm mới tỉ giá -->
    <LinearLayout
        android:id="@+id/api"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_weight="0"
        android:orientation="horizontal">

        <!-- Văn bản hiển thị tỉ giá quy đổi hiện tại -->
        <TextView
            android:id="@+id/tvapi"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1 USD = 23,000 VND"
            android:paddingLeft="50dp"
            android:textColor="#5E6E82"
            android:textStyle="bold" />

        <!-- Nút biểu tượng tải lại/cập nhật tỉ giá -->
        <ImageView
            android:id="@+id/imgrefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="0"
            app:tint="#5E6E82"
            app:srcCompat="@drawable/refresh"
            android:layout_marginEnd="10dp" />
    </LinearLayout>

    <LinearLayout
        style="@style/buttonRow"
        android:layout_margin="2dp">

        <ImageButton
            android:id="@+id/btnchange"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/custom_button2"
            android:src="@drawable/change"
            app:backgroundTint="@null"
            app:tint="#4F46E5" />

        <Button
            android:id="@+id/btnc"
            style="@style/buttonOperator"
            android:background="@drawable/custom_button2"
            android:text="C"
            app:backgroundTint="@null" />

        <ImageButton
            android:id="@+id/btne"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/custom_button2"
            android:src="@drawable/ic_backspace"
            app:backgroundTint="@null"
            app:tint="#4F46E5" />

        <Button
            android:id="@+id/btndiv"
            style="@style/buttonOperator"
            android:background="@drawable/custom_button2"
            android:text="/"
            app:backgroundTint="@null" />
    </LinearLayout>

    <LinearLayout
        style="@style/buttonRow"
        android:layout_margin="2dp">

        <Button
            android:id="@+id/btn7"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="7"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn8"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="8"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn9"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="9"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnmul"
            style="@style/buttonOperator"
            android:background="@drawable/custom_button2"
            android:text="X"
            app:backgroundTint="@null" />
    </LinearLayout>

    <LinearLayout
        style="@style/buttonRow"
        android:layout_margin="2dp">

        <Button
            android:id="@+id/btn4"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="4"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn5"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="5"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn6"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="6"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnsub"
            style="@style/buttonOperator"
            android:background="@drawable/custom_button2"
            android:text="-"
            app:backgroundTint="@null" />
    </LinearLayout>

    <LinearLayout
        style="@style/buttonRow"
        android:layout_margin="2dp">

        <Button
            android:id="@+id/btn1"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="1"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn2"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="2"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn3"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="3"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnadd"
            style="@style/buttonOperator"
            android:background="@drawable/custom_button2"
            android:text="+"
            app:backgroundTint="@null" />
    </LinearLayout>

    <LinearLayout
        style="@style/buttonRow"
        android:layout_margin="2dp">

        <Button
            android:id="@+id/btn0"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="0"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btndot"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text=","
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnpercent"
            style="@style/buttonNumber"
            android:background="@drawable/custom_button1"
            android:text="%"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnequal"
            style="@style/buttonOperator"
            android:background="@drawable/custom_button2"
            android:text="="
            app:backgroundTint="@null" />
    </LinearLayout>

    <!-- Thanh điều hướng bên dưới ứng dụng (Bottom Navigation) dạng chuẩn Material Design -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomnavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        app:itemActiveIndicatorStyle="@null"
        app:itemIconSize="24dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_menu"
        app:paddingBottomSystemWindowInsets="true" />

</LinearLayout>
