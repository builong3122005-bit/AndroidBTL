<?xml version="1.0" encoding="utf-8"?>
<!-- Giao diện màn hình đăng nhập (Login Screen) -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    tools:context=".MainActivity">

    <!-- Tiêu đề trang đăng nhập -->
    <TextView
        android:id="@+id/tvlogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="165dp"
        android:text="ĐĂNG NHẬP"
        android:textColor="#1E1E24"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Guideline dọc để căn chỉnh thẳng hàng các ô nhập liệu -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="130dp" />

    <!-- Nhãn Tài khoản (UID) -->
    <TextView
        android:id="@+id/tvuid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:text="Tài khoản"
        android:textColor="#1E1E24"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintBaseline_toBaselineOf="@+id/edtUid" />

    <!-- Nhãn Mật khẩu -->
    <TextView
        android:id="@+id/tvpsw"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:text="Mật khẩu"
        android:textColor="#1E1E24"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintBaseline_toBaselineOf="@+id/edtPassword" />

    <!-- Ô nhập tên tài khoản (UID) -->
    <EditText
        android:id="@+id/edtUid"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="240dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/custom_edittext_dangnhap"
        android:backgroundTint="@null"
        android:ems="10"
        android:hint="Nhập tài khoản"
        android:textColor="#1E1E24"
        android:textColorHint="#7E8B9B"
        android:paddingLeft="12dp"
        android:inputType="text"
        android:text=""
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ô nhập mật khẩu -->
    <EditText
        android:id="@+id/edtPassword"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/custom_edittext_dangnhap"
        android:backgroundTint="@null"
        android:ems="10"
        android:hint="Nhập mật khẩu"
        android:textColor="#1E1E24"
        android:textColorHint="#7E8B9B"
        android:inputType="textPassword"
        android:paddingStart="12dp"
        android:text=""
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtUid" />

    <!-- Link dẫn đến trang đăng ký -->
    <TextView
        android:id="@+id/tvdangky"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:text="Đăng ký tài khoản"
        android:textColor="#4F46E5"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtPassword" />

    <!-- Nút Đăng nhập -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:background="@drawable/custom_btndangnhap"
        android:text="Đăng nhập"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtPassword" />

    <!-- Tùy chọn đăng nhập với tư cách Khách -->
    <TextView
        android:id="@+id/tvKhach"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Sử dụng tài khoản Khách"
        android:textColor="#4F46E5"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnLogin" />

</androidx.constraintlayout.widget.ConstraintLayout>
