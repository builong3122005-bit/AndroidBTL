<?xml version="1.0" encoding="utf-8"?>
<!-- Giao diện màn hình hiển thị biểu đồ phân tích tỉ giá (Chart Page) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:orientation="vertical"
    tools:context=".BieuDoActivity">

    <!-- Tiêu đề màn hình biểu đồ -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Biểu đồ hình nến"
        android:textColor="#1E1E24"
        android:textStyle="bold"
        android:textSize="25dp"
        android:gravity="center"
        android:layout_marginTop="10dp"
        />

    <!-- Nút quay lại (Back) -->
    <ImageView
        android:id="@+id/imgBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/icon_back"
        android:paddingLeft="10dp"
        app:tint="#1E1E24"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"/>

    <!-- Thông tin biến động giá -->
    <TextView
        android:id="@+id/tvBienDongGia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Biến động giá"
        android:textStyle="italic|bold"
        android:paddingLeft="14dp"
        android:textColor="#5E6E82" />

    <!-- Khu vực hiển thị ngày giờ cập nhật -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView34"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="    " />

        <TextView
            android:id="@+id/txtThoiGian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="10:31 AM"
            android:textColor="#1E1E24" />

        <TextView
            android:id="@+id/textView36"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=", "
            android:textColor="#1E1E24"/>

        <TextView
            android:id="@+id/txtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="07/04/2025"
            android:textColor="#1E1E24"
            android:paddingBottom="5dp"/>
    </LinearLayout>

    <com.github.mikephil.charting.charts.CandleStickChart
        android:id="@+id/candleStickChart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="16dp" />

</LinearLayout>
