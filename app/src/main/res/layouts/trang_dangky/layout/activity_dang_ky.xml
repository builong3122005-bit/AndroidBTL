<?xml version="1.0" encoding="utf-8"?>
<!-- Giao diện màn hình đăng ký tài khoản (Sign Up Screen) -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DangKyActivity"
    android:background="@color/background_main">

    <!-- Tiêu đề trang đăng ký -->
    <TextView
        android:id="@+id/tvregister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="104dp"
        android:text="ĐĂNG KÝ"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.528"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Guideline dọc để căn chỉnh thẳng hàng các ô nhập liệu -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="140dp" />

    <!-- Nhãn Tài khoản -->
    <TextView
        android:id="@+id/tvuid2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:text="Tài khoản"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintBaseline_toBaselineOf="@+id/edtuid2" />

    <!-- Ô nhập Tên tài khoản -->
    <EditText
        android:id="@+id/edtuid2"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/custom_edittext_dangnhap"
        android:ems="10"
        android:hint="Nhập tài khoản"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:paddingLeft="12dp"
        android:inputType="text"
        android:text=""
        app:backgroundTint="@null"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvregister" />

    <!-- Nhãn Họ và tên -->
    <TextView
        android:id="@+id/tvhoten"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:text="Họ và tên"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintBaseline_toBaselineOf="@+id/edthoten" />

    <!-- Ô nhập Họ và tên -->
    <EditText
        android:id="@+id/edthoten"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/custom_edittext_dangnhap"
        android:ems="10"
        android:hint="Nhập họ và tên"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:inputType="text"
        android:paddingLeft="12dp"
        android:text=""
        app:backgroundTint="@null"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtuid2" />

    <!-- Nhãn Mật khẩu -->
    <TextView
        android:id="@+id/tvpasw"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:text="Mật khẩu"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintBaseline_toBaselineOf="@+id/edtpsw2" />

    <!-- Ô nhập Mật khẩu -->
    <EditText
        android:id="@+id/edtpsw2"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/custom_edittext_dangnhap"
        android:ems="10"
        android:paddingLeft="12dp"
        android:hint="Nhập mật khẩu"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:inputType="textPassword"
        app:backgroundTint="@null"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edthoten" />

    <!-- Nhãn Email -->
    <TextView
        android:id="@+id/tvemail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:text="Email"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintBaseline_toBaselineOf="@+id/edtemail" />

    <!-- Ô nhập Email -->
    <EditText
        android:id="@+id/edtemail"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/custom_edittext_dangnhap"
        android:ems="10"
        android:hint="Nhập email"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:paddingLeft="12dp"
        android:inputType="textEmailAddress"
        app:backgroundTint="@null"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtpsw2" />

    <!-- Nhãn Số điện thoại -->
    <TextView
        android:id="@+id/tvsdt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:text="Số điện thoại"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintBaseline_toBaselineOf="@+id/edtsdt" />

    <!-- Ô nhập Số điện thoại -->
    <EditText
        android:id="@+id/edtsdt"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/custom_edittext_dangnhap"
        android:ems="10"
        android:hint="Nhập số điện thoại"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:paddingLeft="12dp"
        android:inputType="phone"
        app:backgroundTint="@null"
        app:layout_constraintStart_toEndOf="@+id/guideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtemail" />

    <!-- Nút Đăng ký -->
    <Button
        android:id="@+id/btndangky"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:background="@drawable/custom_btndangnhap"
        android:text="Đăng ký"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtsdt" />

</androidx.constraintlayout.widget.ConstraintLayout>
